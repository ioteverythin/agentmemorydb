# ======================
# AgentMemoryDB Configuration
# ======================

# Application
APP_NAME=AgentMemoryDB
ENVIRONMENT=development
LOG_LEVEL=INFO
ENABLE_DOCS=true

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://agentmem:agentmem_secret@localhost:5432/agentmemorydb
DATABASE_ECHO=false

# Embedding settings
EMBEDDING_DIMENSION=1536
VECTOR_INDEX_LISTS=100

# Retrieval defaults
DEFAULT_TOP_K=10

# Optional: OpenAI (only needed if using OpenAI embedding provider)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Embedding provider: dummy | openai | cohere | sentence-transformers | ollama
EMBEDDING_PROVIDER=dummy

# Authentication
REQUIRE_AUTH=false

# Feature flags
ENABLE_WEBHOOKS=true
ENABLE_METRICS=true
ENABLE_FULLTEXT_SEARCH=true
ENABLE_ACCESS_TRACKING=true

# WebSocket / MCP / Explorer / Scheduler
ENABLE_WEBSOCKET=true
ENABLE_MCP=true
ENABLE_EXPLORER=true
ENABLE_SCHEDULER=true

# Row Level Security (run migration 004_add_rls first)
ENABLE_RLS=false

# Scheduler intervals (seconds)
# SCHEDULER_CONSOLIDATION_INTERVAL=3600
# SCHEDULER_ARCHIVE_INTERVAL=7200
# SCHEDULER_RECENCY_INTERVAL=1800
# SCHEDULER_CLEANUP_INTERVAL=3600
# SCHEDULER_PRUNE_INTERVAL=86400
# SCHEDULER_STALE_THRESHOLD_DAYS=90
# SCHEDULER_ACCESS_LOG_RETENTION_DAYS=90
